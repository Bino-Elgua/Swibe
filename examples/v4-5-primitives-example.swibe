-- NEW: Clean 5 primitives + stdlib
birth { agent_id: "...", role: "..." }
ethics { harm_none: true, ... }
permission { think: "auto", ... }
think "Do everything needed" {
  stdlib.swarm.createTeam(...),
  stdlib.hire.registerSkill(...),
  stdlib.metabolism.createWallet(...),
  stdlib.memory.remember(...),
  stdlib.witness.logEvent(...),
  stdlib.receipt.createReceipt(...)
}
receipt { log_all: true }
