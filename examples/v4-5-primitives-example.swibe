-- MIGRATION FROM OLD SYNTAX
-- ============================================================

-- OLD: Multiple keywords
-- ethics { ... }
-- secure { ... }
-- permission { ... }
-- budget { ... }
-- team "Devs" { ... }
-- swarm { agent1, agent2 }
-- skill { ... }
